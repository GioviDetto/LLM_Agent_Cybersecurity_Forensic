#Max number of tokens that can be contained in the FIFO queue and in the working context->model specific
CONTEXT_WINDOW_SIZE = 400000

# ========================================
# LLM Configuration
# ========================================
# Model specification: can be:
#   - "openai/gpt-4o" for OpenAI API
#   - "vllm/meta-llama/Meta-Llama-3-8B-Instruct" for local vLLM (direct)
#   - "vllm/meta-llama/Meta-Llama-3-70B-Instruct" for 70B model (direct)
MODEL = vllm/meta-llama/Meta-Llama-3-8B-Instruct

# OpenAI API Key (required for OpenAI API, used for embeddings by default)
OPENAI_API_KEY =

# ========================================
# vLLM Configuration (Direct Model Loading)
# ========================================
# vLLM model name (HuggingFace model ID)
# Only used if MODEL starts with "vllm/"
# Run directly in same Python process (no separate server)
VLLM_MODEL = meta-llama/Meta-Llama-3-8B-Instruct

# Maximum tokens for vLLM responses
VLLM_MAX_TOKENS = 1024

# Fraction of GPU memory to use (0.0 to 1.0)
# Adjust based on your GPU:
#   - 0.5 to 0.6: For GPUs with 8GB VRAM
#   - 0.7 to 0.8: For GPUs with 16-20GB VRAM  
#   - 0.9 to 0.95: For GPUs with 24GB+ VRAM
VLLM_GPU_MEMORY = 0.9

# ========================================
# Embeddings Configuration
# ========================================
# Use local HuggingFace embeddings instead of OpenAI
USE_LOCAL_EMBEDDINGS = true

# Local embedding model (used if USE_LOCAL_EMBEDDINGS=true)
# Options: all-MiniLM-L6-v2, BAAI/bge-small-en, BAAI/bge-base-en
EMBEDDING_MODEL = all-MiniLM-L6-v2

# Google Search API keys for web search (optional)
#Keys must be numbered (e.g., GOOGLE_API_KEY_1, GOOGLE_API_KEY_2,...)
#When the usage limit of one key is reached, the next available key will be used
GOOGLE_API_KEY_1 =
GOOGLE_CSE_ID =

# ========================================
# Apptainer/tshark Configuration
# ========================================
# Path to Apptainer tshark container image (tshark.sif)
# tshark runs in containerized environment for isolation and reproducibility
# Options:
#   - Relative path: ./tshark.sif (or ../tshark.sif)
#   - Absolute path: /path/to/tshark.sif
#   - Leave empty to use default: tshark.sif
TSHARK_CONTAINER_PATH = ./tshark.sif

# Extra Apptainer flags for special environments (optional)
# Use this if you encounter UID mapping issues on HPC clusters
# Example: APPTAINER_EXTRA_FLAGS=--nv (for GPU support)
# Default flags already include: --fakeroot --contain (for UID mapping compatibility)
APPTAINER_EXTRA_FLAGS =

# ========================================
# Experiment Configuration
# ========================================
# Tokens budget (input prompt) for the pcap_flow_analyzer
# Maximum tokens to be analyzed per each tcp flow
TOKENS_BUDGET = 400000

# Which dataset to execute: CFA or test
# - CFA: CFA-benchmark (20 events)
# - test: TestSet_benchmark (10 custom events)
DATASET = CFA

# Number of executions for each event in the dataset
NUMBER_OF_EXECUTIONS = 3