#Max number of tokens that can be contained in the FIFO queue and in the working context->model specific
CONTEXT_WINDOW_SIZE = 400000

# ========================================
# LLM Configuration
# ========================================
# Model specification: can be:
#   - "openai/gpt-4o" for OpenAI API
#   - "vllm/meta-llama/Meta-Llama-3-8B-Instruct" for local vLLM
#   - "vllm/meta-llama/Meta-Llama-3-70B-Instruct" for 70B model
MODEL = vllm/meta-llama/Meta-Llama-3-8B-Instruct

# OpenAI API Key (required for OpenAI API, used for embeddings by default)
OPENAI_API_KEY =

# ========================================
# vLLM Configuration (for local models)
# ========================================
# vLLM server base URL
VLLM_BASE_URL = http://localhost:8000/v1

# vLLM model name (only used if MODEL starts with "vllm/")
VLLM_MODEL = meta-llama/Meta-Llama-3-8B-Instruct

# Maximum tokens for vLLM responses
VLLM_MAX_TOKENS = 1024

# vLLM server timeout in seconds
VLLM_TIMEOUT = 200

# ========================================
# Embeddings Configuration
# ========================================
# Use local HuggingFace embeddings instead of OpenAI
USE_LOCAL_EMBEDDINGS = true

# Local embedding model (used if USE_LOCAL_EMBEDDINGS=true)
# Options: all-MiniLM-L6-v2, BAAI/bge-small-en, BAAI/bge-base-en
EMBEDDING_MODEL = all-MiniLM-L6-v2

# Google Search API keys for web search (optional)
#Keys must be numbered (e.g., GOOGLE_API_KEY_1, GOOGLE_API_KEY_2,...)
#When the usage limit of one key is reached, the next available key will be used
GOOGLE_API_KEY_1 =
GOOGLE_CSE_ID =

# ========================================
# Experiment Configuration
# ========================================
#Tokens budget (input prompt) for the pcap_flow_analyzer, how many tokens maximum to be analyzed per each tcp flow
TOKENS_BUDGET = 400000

#Explicit which events to execute: CFA bench (CFA) or the testSet with the newly created 10 events (test)
DATASET = CFA

#Specify the number of executions for the specific set of events
NUMBER_OF_EXECUTIONS = 3